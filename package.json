{
  "name": "modulo-banca-electronica",
  "version": "1.0.0",
  "description": "Módulo simulado de banca electrónica con pipeline CI y análisis SAST",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --coverage --coverageDirectory=coverage",
    "test:verbose": "jest --coverage --verbose",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "sonar": "sonar-scanner"
  },
  "keywords": ["banca", "ci", "sast", "sonarqube"],
  "author": "Estudiante",
  "license": "MIT",
  "devDependencies": {
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "sonarqube-scanner": "3.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": ["text", "lcov", "clover"]
  }
}
